# ------------------------------------------------------------------------------
# CONFIGURACIÓN DE ENTORNO (REFERENCIA PARA COES)
# ------------------------------------------------------------------------------

# --- GENERAL ---
DEBUG=True
PORT=8005
ENVIRONMENT=develop
DJANGO_SETTINGS_MODULE=cfg.settings.develop
SECRET_KEY=django-insecure-development-key-change-me-in-production

# En desarrollo usa * o localhost. En producción: dominio.com,www.dominio.com (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1,*
# Requerido en Django 4.0+ para formularios (incluir protocolo y sin barra final)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- DATABASE ---
DB_ENGINE=tu_db
DB_NAME=user
DB_USER=user
DB_PASSWORD=user
DB_HOST=db
DB_PORT=5432

# --- REDIS & CELERY ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- EMAIL (SMTP CONFIG) ---
# Cambiar a django.core.mail.backends.console.EmailBackend para ver correos en terminal
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
TS_EMAIL_HOST=smtp.gmail.com
TS_EMAIL_PORT=587
TS_EMAIL_TLS=True
TS_EMAIL_SSL=False
TS_EMAIL_USER=tu_correo@gmail.com
TS_EMAIL_PASSWORD=fpdw fpyz plni qfkd
DEFAULT_FROM_EMAIL=Email <no-reply@email.com>

# --- CORS ---
# Orígenes permitidos para peticiones desde el frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- PRODUCTION SECURITY ---
# Solo activar (True) cuando tengas certificados SSL/HTTPS configurados
SECURE_SSL_REDIRECT=False